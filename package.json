{
	"name": "exam-genius",
	"version": "0.0.0",
	"license": "MIT",
	"scripts": {
		"dev": "turbo run dev",
		"dev:dashboard": "turbo run dev --filter=@exam-genius/dashboard-app",
		"dev:landing": "turbo run dev --filter=@exam-genius/landing-page",
		"dev:dashboard:doppler": "doppler run -c loc -p exam-genius -- turbo run dev --filter=@exam-genius/dashboard-app",
		"build": "turbo run build",
		"build:dashboard": "npx prisma generate && turbo run build --filter=@exam-genius/dashboard-app",
		"build:landing": "turbo run build --filter=@exam-genius/landing-page",
		"start": "turbo run start",
		"start:dashboard": "turbo run start --filter=@exam-genius/dashboard-app",
		"start:landing": "turbo run start --filter=@exam-genius/landing-page",
		"lint": "turbo run lint",
		"lint:dashboard": "turbo run lint --filter=@exam-genius/dashboard-app",
		"lint:landing": "turbo run lint --filter=@exam-genius/landing-page",
		"test": "turbo run test",
		"ngrok": "ngrok http --domain=present-shepherd-shining.ngrok-free.app 3000 --config=./bin/ngrok.yml",
		"prisma:sync": "npx prismerge -i prismerge.json && npx prisma generate && npx prisma db push",
		"prisma:generate": "npx prismerge -i prismerge.json && npx prisma generate",
		"prisma:merge": "npx prismerge -i prismerge.json",
		"prisma:studio": "npx prisma studio",
		"prisma:push": "npx prisma db push",
		"prisma:pull": "npx prisma db pull",
		"create-env-file:dashboard": "doppler secrets download --no-file --format env > ./apps/dashboard-app/.env -p exam-genius -c loc",
		"webhookthing": "npx webhookthing@latest",
		"stripe-local-webhook": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
		"doppler:sync-env": "doppler secrets download --no-file --format env > .env.doppler"
	},
	"private": true,
	"packageManager": "pnpm@9.0.0",
	"engines": {
		"node": "22.x"
	},
	"dependencies": {
		"date-fns": "^4.1.0",
		"next": "^15.5.12",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@babel/core": "^7.14.5",
		"@babel/preset-react": "^7.14.5",
		"@prisma-utils/prismerge": "^1.7.0",
		"@swc/core": "1.5.7",
		"@swc/jest": "0.2.37",
		"@testing-library/react": "15.0.6",
		"@trpc/next": "^11.7.2",
		"@types/jest": "29.5.14",
		"@types/node": "^22.0.0",
		"@types/react": "18.3.1",
		"@types/react-dom": "18.3.0",
		"@types/react-scroll": "^1.8.10",
		"@types/ws": "^8.5.10",
		"@typescript-eslint/eslint-plugin": "7.18.0",
		"@typescript-eslint/parser": "7.18.0",
		"autoprefixer": "10.4.13",
		"babel-jest": "29.7.0",
		"eslint": "9.24.0",
		"eslint-config-next": "15.5.12",
		"eslint-config-prettier": "10.1.1",
		"eslint-plugin-import": "2.27.5",
		"eslint-plugin-jsx-a11y": "6.7.1",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-hooks": "5.0.0",
		"jest": "29.7.0",
		"jest-environment-jsdom": "29.7.0",
		"postcss": "8.4.38",
		"postcss-preset-mantine": "^1.17.0",
		"postcss-simple-vars": "^7.0.1",
		"prettier": "^3.5.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"prisma": "^7.1.0",
		"tailwindcss": "3.4.3",
		"ts-jest": "29.1.5",
		"ts-node": "10.9.1",
		"turbo": "^2.8.10",
		"typescript": "5.5.4"
	}
}
