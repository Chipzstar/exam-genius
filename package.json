		"@prisma/adapter-neon": "^7.1.0",
		"@prisma/adapter-pg": "^7.1.0",
		"@prisma/client": "^7.1.0",
		"@sentry/nextjs": "^7.47.0",
		"@stripe/stripe-js": "^1.52.0",
		"@t3-oss/env-nextjs": "^0.13.8",
