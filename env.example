# Prisma Accelerate (runtime) — from Prisma Data Platform
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=<API_KEY>"
# Direct Postgres URL for Prisma CLI (migrate, introspect, studio against direct DB)
DIRECT_DATABASE_URL="postgresql://<USERNAME>:<PASSWORD>@<HOST>/<DB_NAME>?sslmode=require"
# Optional legacy: unpooled URL if your provider distinguishes pooled vs direct
DATABASE_URL_UNPOOLED="postgresql://<USERNAME>:<PASSWORD>@<HOST>/<DB_NAME>?sslmode=require"

AQA_BIOLOGY_COURSE_PRICE_ID="<REDACTED>"
