NEXT_PUBLIC_AXIOM_DATASET="<your-axiom-dataset>"
NEXT_PUBLIC_AXIOM_INGEST_ENDPOINT="<REDACTED>"
NEXT_PUBLIC_AXIOM_TOKEN="<your-axiom-api-token>"
