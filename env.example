# Shared secret for dashboard → Railway Fastify /server/* and UploadThing extract callback
BACKEND_SHARED_SECRET="<generate-a-long-random-string>"

# UploadThing (reference PDF uploads)
UPLOADTHING_TOKEN="<uploadthing-token>"

# Upstash Redis (optional; rate limits disabled if unset)
UPSTASH_REDIS_REST_URL="https://<id>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<token>"

# Map Stripe price IDs to User.plan (JSON object, e.g. {"price_xxx":"plus"})
STRIPE_PLAN_MAP="{}"

# Feature flags (client; set to "true" to enable)
NEXT_PUBLIC_FLAG_STRUCTURED_QUESTIONS="false"
NEXT_PUBLIC_FLAG_QUESTION_EDITS="false"
NEXT_PUBLIC_FLAG_PAPER_REFERENCES="false"
NEXT_PUBLIC_FLAG_AI_MARKING="false"

# Optional model override for streamed question edits
# OPENAI_QUESTION_EDIT_MODEL="gpt-4o-mini"

PORT="3000"
