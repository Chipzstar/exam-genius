model Course {
  id         Int       @id @unique @default(autoincrement())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  course_id  String    @unique
  name       String
  subject    Subject
  code       String?
  user_id    String
  user       User      @relation(fields: [user_id], references: [clerk_id], onDelete: Cascade)
  exam_board ExamBoard
  exam_level ExamLevel @default(a_level)
  product_id String?
  year_level Int
  papers     Paper[]
  paperReferences PaperReference[]

  @@index([user_id])
}

enum ExamLevel {
  a_level
  as_level
}

enum Subject {
  maths
  biology
  chemistry
  economics
  physics
  psychology
}

enum ExamBoard {
  edexcel
  aqa
  ocr
}
