generator client {
    provider    = "prisma-client"
    output      = "../libs/shared/prisma"
    engineType  = "client" // enable Prisma ORM without Rust
}

/// Zod schemas for API contracts (see https://github.com/omar-dulaimi/prisma-zod-generator).
generator zod {
    provider   = "prisma-zod-generator"
    output     = "../libs/shared/prisma-zod"
}

datasource db {
    provider  = "postgresql"
}
