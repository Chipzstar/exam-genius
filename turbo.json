{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["babel.config.json", ".env.local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": { "cache": false, "persistent": true },
    "start": { "cache": false, "persistent": true },
    "lint": { "dependsOn": ["^lint"], "cache": true },
    "test": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "jest.config.*", "jest.preset.js"]
    }
  },
  "globalEnv": [
    "APP_BASE_URL",
    "AQA_BIOLOGY_COURSE_PRICE_ID",
    "AQA_CHEMISTRY_COURSE_PRICE_ID",
    "AQA_ECONOMICS_COURSE_PRICE_ID",
    "AQA_MATHS_COURSE_PRICE_ID",
    "AQA_PHYSICS_COURSE_PRICE_ID",
    "AQA_PSYCHOLOGY_COURSE_PRICE_ID",
    "AXIOM_DATASET",
    "AXIOM_ORG_ID",
    "AXIOM_TOKEN",
    "BACKEND_HOST",
    "BIOLOGY_PAPER_PRICE_ID",
    "CHEMISTRY_PAPER_PRICE_ID",
    "CLERK_SECRET_KEY",
    "CLERK_WEBHOOK_SIGNING_SECRET",
    "DATABASE_HOST",
    "DATABASE_NAME",
    "DATABASE_PASSWORD",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "DATABASE_USERNAME",
    "DOPPLER_CONFIG",
    "DOPPLER_ENVIRONMENT",
    "DOPPLER_PROJECT",
    "ECONOMICS_PAPER_PRICE_ID",
    "EDEXCEL_BIOLOGY_COURSE_PRICE_ID",
    "EDEXCEL_CHEMISTRY_COURSE_PRICE_ID",
    "EDEXCEL_ECONOMICS_COURSE_PRICE_ID",
    "EDEXCEL_MATHS_COURSE_PRICE_ID",
    "EDEXCEL_PHYSICS_COURSE_PRICE_ID",
    "EDEXCEL_PSYCHOLOGY_COURSE_PRICE_ID",
    "GOOGLE_OAUTH_CLIENT_ID",
    "GOOGLE_OAUTH_CLIENT_SECRET",
    "MATHS_PAPER_PRICE_ID",
    "NEXT_PUBLIC_AXIOM_DATASET",
    "NEXT_PUBLIC_AXIOM_INGEST_ENDPOINT",
    "NEXT_PUBLIC_AXIOM_TOKEN",
    "NEXT_PUBLIC_BACKEND_HOST",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL",
    "NEXT_PUBLIC_CLERK_SIGN_IN_URL",
    "NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL",
    "NEXT_PUBLIC_CLERK_SIGN_UP_URL",
    "NEXT_PUBLIC_SENTRY_DSN",
    "NEXT_PUBLIC_SENTRY_ENV",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
    "NX_CACHE_DIRECTORY",
    "NX_SKIP_NX_CACHE",
    "NX_VERBOSE_LOGGING",
    "OCR_BIOLOGY_COURSE_PRICE_ID",
    "OCR_CHEMISTRY_COURSE_PRICE_ID",
    "OCR_ECONOMICS_COURSE_PRICE_ID",
    "OCR_MATHS_COURSE_PRICE_ID",
    "OCR_PHYSICS_COURSE_PRICE_ID",
    "OCR_PSYCHOLOGY_COURSE_PRICE_ID",
    "OPENAI_API_KEY",
    "PHYSICS_PAPER_PRICE_ID",
    "PSYCHOLOGY_PAPER_PRICE_ID",
    "REDIS_HOST",
    "REDIS_PASSWORD",
    "REDIS_PORT",
    "REDIS_URL",
    "REDIS_USERNAME",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_DSN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET"
  ]
}
